generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// TipoItem:        MANTIMENTO | UTENSILIO | OUTRO
// TipoMovimentacao: ENTRADA | SAIDA
// StatusPatrimonio: ATIVO | INATIVO | EM_MANUTENCAO | DESCARTADO

// papel: ADMINISTRADOR | OPERADOR | VISUALIZADOR
model Usuario {
  id       String  @id @default(cuid())
  nome     String
  email    String  @unique
  senha    String
  papel    String  @default("VISUALIZADOR") // ADMINISTRADOR | OPERADOR | VISUALIZADOR
  ativo    Boolean @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  movimentacoes Movimentacao[]
  doacoes       Doacao[]

  @@map("usuarios")
}

model Categoria {
  id       String   @id @default(cuid())
  nome     String   @unique
  tipo     String   // MANTIMENTO | UTENSILIO | OUTRO
  criadoEm DateTime @default(now()) @map("criado_em")

  itens Item[]

  @@map("categorias")
}

model Localizacao {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm  DateTime @default(now()) @map("criado_em")

  itens       Item[]
  patrimonios Patrimonio[]

  @@map("localizacoes")
}

model Item {
  id               String   @id @default(cuid())
  nome             String
  descricao        String?
  unidade          String
  quantidade       Float    @default(0)
  quantidadeMinima Float    @default(0) @map("quantidade_minima")
  ativo            Boolean  @default(true)
  criadoEm        DateTime @default(now()) @map("criado_em")
  atualizadoEm    DateTime @updatedAt @map("atualizado_em")

  categoriaId   String? @map("categoria_id")
  localizacaoId String? @map("localizacao_id")

  categoria    Categoria?   @relation(fields: [categoriaId], references: [id])
  localizacao  Localizacao? @relation(fields: [localizacaoId], references: [id])
  movimentacoes Movimentacao[]

  @@index([categoriaId])
  @@index([localizacaoId])
  @@map("itens")
}

model Movimentacao {
  id         String   @id @default(cuid())
  tipo       String   // ENTRADA | SAIDA
  quantidade Float
  observacao String?
  criadoEm  DateTime @default(now()) @map("criado_em")

  itemId    String @map("item_id")
  usuarioId String @map("usuario_id")

  item    Item    @relation(fields: [itemId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([itemId])
  @@index([criadoEm])
  @@map("movimentacoes")
}

model Patrimonio {
  id             String    @id @default(cuid())
  nome           String
  descricao      String?
  numeroSerie    String?   @map("numero_serie")
  valorAquisicao Float?    @map("valor_aquisicao")
  dataAquisicao  DateTime? @map("data_aquisicao")
  status         String    @default("ATIVO") // ATIVO | INATIVO | EM_MANUTENCAO | DESCARTADO
  criadoEm      DateTime  @default(now()) @map("criado_em")
  atualizadoEm  DateTime  @updatedAt @map("atualizado_em")

  localizacaoId String? @map("localizacao_id")

  localizacao Localizacao? @relation(fields: [localizacaoId], references: [id])

  @@index([status])
  @@map("patrimonios")
}

model Doacao {
  id            String   @id @default(cuid())
  doador        String?
  contato       String?
  descricao     String
  quantidade    Float?
  unidade       String?
  valorEstimado Float?   @map("valor_estimado")
  dataDoacao    DateTime @default(now()) @map("data_doacao")
  observacoes   String?
  criadoEm     DateTime @default(now()) @map("criado_em")

  usuarioId String? @map("usuario_id")

  usuario Usuario? @relation(fields: [usuarioId], references: [id])

  @@index([dataDoacao])
  @@map("doacoes")
}
