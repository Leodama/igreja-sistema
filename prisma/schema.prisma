generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// papel: ADMINISTRADOR | OPERADOR | VISUALIZADOR
model Usuario {
  id        String   @id @default(cuid())
  nome      String
  email     String   @unique
  senha     String
  papel     String   @default("VISUALIZADOR") // ADMINISTRADOR | OPERADOR | VISUALIZADOR
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  movimentacoes Movimentacao[]
  emprestimos   Emprestimo[]

  @@map("usuarios")
}

model Categoria {
  id        String   @id @default(cuid())
  nome      String   @unique
  tipo      String   // MANTIMENTO | UTENSILIO | OUTRO
  criadoEm DateTime @default(now()) @map("criado_em")

  itens Item[]

  @@map("categorias")
}

model Localizacao {
  id        String   @id @default(cuid())
  nome      String   @unique
  descricao String?
  ativo     Boolean  @default(true)
  criadoEm DateTime @default(now()) @map("criado_em")

  itens Item[]

  @@map("localizacoes")
}

model Item {
  id               String    @id @default(cuid())
  nome             String
  descricao        String?
  unidade          String
  quantidade       Float     @default(0)
  quantidadeMinima Float     @default(0) @map("quantidade_minima")
  ativo            Boolean   @default(true)
  status           String    @default("ATIVO") // ATIVO | INATIVO | EM_MANUTENCAO | DESCARTADO
  numeroSerie      String?   @map("numero_serie")
  valorAquisicao   Float?    @map("valor_aquisicao")
  dataAquisicao    DateTime? @map("data_aquisicao")
  // origem: DOACAO | COMPRA | null
  origem           String?
  nomeDoador       String?   @map("nome_doador")
  valorCompra      Float?    @map("valor_compra")
  fornecedor       String?
  numeroNfe        String?   @map("numero_nfe")
  criadoEm        DateTime  @default(now()) @map("criado_em")
  atualizadoEm    DateTime  @updatedAt @map("atualizado_em")

  categoriaId   String? @map("categoria_id")
  localizacaoId String? @map("localizacao_id")

  categoria    Categoria?   @relation(fields: [categoriaId], references: [id])
  localizacao  Localizacao? @relation(fields: [localizacaoId], references: [id])
  movimentacoes Movimentacao[]
  emprestimos   Emprestimo[]

  @@index([categoriaId])
  @@index([localizacaoId])
  @@map("itens")
}

model Movimentacao {
  id               String    @id @default(cuid())
  tipo             String    // ENTRADA | SAIDA
  quantidade       Float
  observacao       String?
  destinatario     String?
  dataMovimentacao DateTime? @map("data_movimentacao")
  criadoEm        DateTime  @default(now()) @map("criado_em")

  itemId    String @map("item_id")
  usuarioId String @map("usuario_id")

  item    Item    @relation(fields: [itemId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([itemId])
  @@index([criadoEm])
  @@map("movimentacoes")
}

model Emprestimo {
  id                  String    @id @default(cuid())
  quantidade          Float     @default(1)
  evento              String?
  responsavel         String
  observacao          String?
  dataSaida           DateTime  @default(now()) @map("data_saida")
  dataRetornoPrevisto DateTime? @map("data_retorno_previsto")
  dataRetorno         DateTime? @map("data_retorno")
  status              String    @default("EM_USO") // EM_USO | RETORNADO
  criadoEm           DateTime  @default(now()) @map("criado_em")

  itemId    String @map("item_id")
  usuarioId String @map("usuario_id")

  item    Item    @relation(fields: [itemId], references: [id])
  usuario Usuario @relation(fields: [usuarioId], references: [id])

  @@index([itemId])
  @@index([status])
  @@map("emprestimos")
}
